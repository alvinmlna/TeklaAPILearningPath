# Training Tracker — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed.
# In development: place .env in the project root.
# In production:  place .env next to the installed .exe
# ─────────────────────────────────────────────────────────────────────────────

# Path to the shared data.json file.
# Use a UNC path (\\server\share\data.json) for network storage.
# Leave blank to use the default per-user AppData location.
#
# Examples:
#   DATA_PATH=\\\\FILESERVER\\Training\\data.json
#   DATA_PATH=Z:\\Training\\data.json
#   DATA_PATH=C:\\Users\\Shared\\training-data.json
#
DATA_PATH=
